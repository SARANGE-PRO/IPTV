# =============================================================================
#  Variables d'environnement — IPTV PWA
#  Copier en `.env.local` (jamais commit). Ne prefixer par NEXT_PUBLIC_ que ce
#  qui peut etre expose au client. Les cles sensibles restent cote serveur.
# =============================================================================

# TMDB — utilise UNIQUEMENT cote serveur (Route Handler /api/tmdb). Etape 9.
# Jamais NEXT_PUBLIC_. Ne jamais appeler TMDB directement depuis le client.
TMDB_API_KEY=

# Passerelle media auto-hebergee : transcode les MKV/AVI en fMP4 lisible sur
# iPhone/iPad, et sert de relais HTTPS pour un Xtream HTTP-only (mixed-content).
# Exemple : https://media.example.com (sans slash final). Voir infra/media-gateway.
# NB : les images ne passent JAMAIS par ce relais (secureImageSrc).
#
# Il SUFFIT de renseigner cette URL : l'app sonde /_health a la demande et
# n'active le transcodage MKV in-app QUE si la passerelle repond ; sinon elle
# bascule proprement vers VLC. (L'ancien flag NEXT_PUBLIC_MEDIA_GATEWAY_TRANSCODE
# n'est plus lu ni necessaire.)
NEXT_PUBLIC_MEDIA_GATEWAY_URL=

# Source EXTERNE (optionnelle) d'evenements sportifs pour le header d'accueil :
# URL(s) d'un EPG XMLTV public (ex. iptv-org/epg) — plusieurs separees par des
# virgules. Cote SERVEUR uniquement (jamais NEXT_PUBLIC_), lue par la route
# /api/sport-events qui parse le XMLTV, classe foot/MMA et cache 6h. Si vide,
# l'app retombe sur le scan EPG Xtream in-app. Idealement rafraichi par un
# Vercel Cron (vercel.json). Exemple : SPORT_EPG_URL=https://exemple.com/fr.xml
SPORT_EPG_URL=

# --- Notes ---
# Les identifiants Xtream ne sont PAS des variables d'env : ils sont saisis
# dans l'interface de connexion puis stockes localement (secureSessionService).
