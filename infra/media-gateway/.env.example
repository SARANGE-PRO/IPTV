# --- Passerelle media auto-hebergee (maison) ---

# Origine HTTP Xtream (schema + host + port, SANS chemin final).
UPSTREAM_ORIGIN=http://xtream.example.net:80

# Port local de la passerelle Windows.
PORT=3000

# Token du Cloudflare Tunnel (Zero Trust > Networks > Tunnels > ton tunnel).
# Le hostname public du tunnel doit router vers  http://gateway:8080
TUNNEL_TOKEN=

# Hotes supplementaires eventuels (logos, sous-domaines). UPSTREAM_ORIGIN est
# toujours autorise, et les redirections (CDN tokenise) sont suivies meme si
# leur IP change — pas besoin de les lister ici.
ALLOWED_HOSTS=

# Transcodage a la volee : 1 = actif (defaut), 0 = passthrough seul.
TRANSCODE=1

# Codec video du transcodage :
#   copy    (defaut) = remux uniquement, tres leger. Safari iOS/iPadOS lit
#                      alors H.264 ET HEVC. Ideal pour iPhone/iPad.
#   libx264          = re-encodage universel (Chrome/Firefox compris) mais
#                      gourmand en CPU (eviter sur Raspberry Pi 1080p).
VIDEO_CODEC=copy

# Optionnel sous Windows : le lanceur detecte automatiquement ffmpeg.
FFMPEG_PATH=

# Optionnel : forcer un User-Agent amont (defaut VLC).
UPSTREAM_USER_AGENT=
