# Domaine public pointe vers l'IP du VPS. Caddy obtient et renouvelle le TLS.
MEDIA_DOMAIN=media.example.com

# Origine HTTP Xtream, port compris et sans chemin final.
UPSTREAM_ORIGIN=http://xtream.example.net:8080

# Hôtes supplementaires eventuellement references dans les playlists/logos,
# separes par des virgules. UPSTREAM_ORIGIN est toujours autorisee.
# Utiliser host:port lorsqu'un port non standard est present.
ALLOWED_HOSTS=
